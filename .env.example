# ============================================
# CEREBRUM BIOLOGY ACADEMY - Environment Configuration Template
# ============================================
# Copy this file to .env.local and fill in your actual values
# Command: cp .env.example .env.local
# ============================================

# ============================================
# APPLICATION SETTINGS
# ============================================
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NODE_ENV=development

# ============================================
# DATABASE (PostgreSQL via Supabase)
# ============================================
DATABASE_URL="postgresql://username:password@host:5432/database"
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ============================================
# AUTHENTICATION
# ============================================
AUTH_SECRET=generate-a-random-secret-key-here
AUTH_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=generate-a-random-secret-key-here
AUTH_TRUST_HOST=true
ADMIN_EMAIL=admin@cerebrumbiologyacademy.com
ADMIN_PASSWORD_HASH=generate-with-bcrypt
BCRYPT_ROUNDS=12

# Social login (OAuth) — providers only activate when both id + secret are set.
# Google: create a Web OAuth client at https://console.cloud.google.com/apis/credentials
# (redirect URI: <site-url>/api/auth/callback/google). GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET
# are accepted as fallbacks for the Google pair.
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
# Facebook: create an app with the "Facebook Login" product at https://developers.facebook.com
# (redirect URI: <site-url>/api/auth/callback/facebook).
AUTH_FACEBOOK_ID=your-facebook-app-id
AUTH_FACEBOOK_SECRET=your-facebook-app-secret

# ============================================
# ANALYTICS & TRACKING
# ============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-11121440988

# Facebook/Meta Pixel & Conversion API
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your-facebook-pixel-id
FACEBOOK_ACCESS_TOKEN=your-facebook-conversion-api-access-token
FACEBOOK_TEST_EVENT_CODE=TEST12345

# ============================================
# ERROR TRACKING (Sentry)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-sentry-organization
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Cashfree (second live gateway — checkout silently fails if unset)
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key

# ============================================
# WHATSAPP BUSINESS API
# ============================================
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TEST_PHONE=+919876543210

# ============================================
# ZOOM INTEGRATION (Optional)
# ============================================
ZOOM_API_URL=https://api.zoom.us/v2
ZOOM_ACCOUNT_ID=your-account-id
ZOOM_CLIENT_ID=your-client-id
ZOOM_CLIENT_SECRET=your-client-secret

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@cerebrumbiologyacademy.com

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=sk-proj-your-key-here

# ============================================
# IMAGE SERVICES
# ============================================
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
OPENAI_API_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_API_URL=https://api.anthropic.com/v1
GOOGLE_AI_API_KEY=your-google-ai-key
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_AI_API_URL=https://generativelanguage.googleapis.com/v1
AI_MODEL_PREFERENCE=claude-3.5-sonnet
AI_CACHE_ENABLED=true
AI_COST_TRACKING=true
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ============================================
# REDIS (Optional - Required for Rate Limiting)
# ============================================
REDIS_URL=
REDIS_TOKEN=
REDIS_PRIMARY_URL=
REDIS_CLUSTER_MODE=false

# ============================================
# CONTACT & SUPPORT
# ============================================
CONTACT_EMAIL=info@cerebrumbiologyacademy.com
SUPPORT_PHONE=+918826444334

# ============================================
# QUIZ COMPETITION
# ============================================
QUIZ_PARTICIPANT_SECRET=generate-a-64-char-hex-secret-here
QUIZ_CLEANUP_SECRET=generate-a-64-char-hex-secret-here

# ============================================
# CRON JOBS
# ============================================
CRON_SECRET=your-cron-secret-key-here

# ============================================
# APP URLS (additional)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_ANALYTICS_ID=

# ============================================
# JWT TOKENS (server-side session/refresh)
# ============================================
JWT_SECRET=generate-a-random-64-char-secret
JWT_REFRESH_SECRET=generate-a-random-64-char-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FEEDBACK_TOKEN_SECRET=generate-a-random-secret

# ============================================
# ADMIN / AUTHORIZATION
# ============================================
ADMIN_API_KEY=generate-a-random-secret
ADMIN_ACCESS_KEY=generate-a-random-secret
ADMIN_ACCESS_KEYS=
ADMIN_ACCESS_KEYS_JSON=
ADMIN_BEARER_TOKEN=generate-a-random-secret
ADMIN_SECRET_KEY=generate-a-random-secret
ADMIN_PHONE=+91xxxxxxxxxx
ADMIN_PHONE_NUMBER=+91xxxxxxxxxx
ADMIN_WHATSAPP_NUMBER=+91xxxxxxxxxx
ADMIN_NOTIFICATION_WHATSAPP=+91xxxxxxxxxx
FREE_RESOURCES_ADMIN_PASSWORD=
ALERT_EMAIL=alerts@cerebrumbiologyacademy.com
DEV_TEAM_EMAIL=dev@cerebrumbiologyacademy.com

# ============================================
# DATABASE - mTLS + read replicas (optional)
# ============================================
DATABASE_CA_CERT=
DATABASE_CLIENT_CERT=
DATABASE_CLIENT_KEY=
DATABASE_READ_REPLICAS=

# ============================================
# REDIS - extended config (Upstash + self-hosted)
# ============================================
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PREFER_UPSTASH=true

# ============================================
# CLOUDFLARE (Images + Stream)
# ============================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_ACCOUNT_HASH=
CLOUDFLARE_IMAGES_API_TOKEN=
CLOUDFLARE_STREAM_KEY_ID=
CLOUDFLARE_STREAM_KEY_PEM=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=

# ============================================
# FIREBASE (legacy — verify if still wired post NextAuth migration)
# ============================================
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_WEBHOOK_SECRET=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# ============================================
# PAYMENTS - Razorpay (client-side key)
# ============================================
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX

# Set to "true" to offer Cashfree as a second gateway at checkout. Requires
# CASHFREE_APP_ID + CASHFREE_SECRET_KEY (above) to be set. When unset/false,
# checkout stays Razorpay-only and the payment-method selector is hidden.
NEXT_PUBLIC_CASHFREE_ENABLED=false

# ============================================
# PAYMENTS - Stripe (verify if still in use; Razorpay is primary)
# ============================================
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# PAYMENTS - PayPal (verify if still in use)
# ============================================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ============================================
# WHATSAPP - additional secrets
# ============================================
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
COUNSELOR_WHATSAPP_NUMBER=+91xxxxxxxxxx
OWNER_WHATSAPP_NUMBER=+91xxxxxxxxxx

# ============================================
# WHATSAPP / SMS - Interakt
# ============================================
INTERAKT_API_KEY=
INTERAKT_PHONE_NUMBER_ID=
INTERAKT_WEBHOOK_SECRET=

# ============================================
# SMS / WHATSAPP - MSG91
# ============================================
MSG91_AUTH_KEY=
MSG91_ROUTE=4
MSG91_SENDER_ID=
MSG91_SMS_TEMPLATE_ID=
MSG91_WHATSAPP_NUMBER=
MSG91_WHATSAPP_TEMPLATE_ID=

# ============================================
# SMS - Twilio
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# EMAIL - Resend / SendGrid
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@cerebrumbiologyacademy.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cerebrumbiologyacademy.com
EMAIL_API_URL=

# ============================================
# ZOOM SDK (in-browser meeting embed)
# ============================================
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=
ZOOM_USER_ID=

# ============================================
# GOOGLE ADS API (conversion uploads)
# ============================================
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# ============================================
# ANALYTICS - extended
# ============================================
GA_API_SECRET=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
CLARITY_ENABLED=false
HOTJAR_ENABLED=false

# ============================================
# SENTRY (server-side DSN; client side is NEXT_PUBLIC_SENTRY_DSN above)
# ============================================
SENTRY_DSN=

# ============================================
# WEBHOOKS - inbound (lead sources + generic)
# ============================================
WEBHOOK_SECRET=generate-a-random-secret
GENERIC_WEBHOOK_SECRET=generate-a-random-secret
ALLOW_UNSIGNED_WEBHOOKS=false
WEBHOOK_SECRET_GOOGLE_ADS=
WEBHOOK_SECRET_JUSTDIAL=
WEBHOOK_SECRET_META_ADS=
WEBHOOK_SECRET_SULEKHA=

# ============================================
# MONITORING & ALERTS
# ============================================
MONITORING_WEBHOOK_URL=
SECURITY_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
EMAIL_ALERTS_ENABLED=false
SMS_ALERTS_ENABLED=false
LOG_LEVEL=info

# ============================================
# SEO - IndexNow
# ============================================
INDEXNOW_API_SECRET=
INDEXNOW_KEY=

# ============================================
# VERCEL BLOB STORAGE
# ============================================
BLOB_READ_WRITE_TOKEN=
VERCEL_BLOB_READ_WRITE_TOKEN=

# ============================================
# SUPPORT
# ============================================
SUPPORT_API_KEY=
SUPPORT_API_URL=
SUPPORT_PHONE_NUMBER=+918826444334

# ============================================
# INSTANT APP (deep links)
# ============================================
INSTANT_APP_ADMIN_TOKEN=
NEXT_PUBLIC_INSTANT_APP_ID=

# ============================================
# COLLABORATIVE / WEBSOCKETS
# ============================================
COLLABORATIVE_WS_PORT=4001
NEXT_PUBLIC_COLLABORATIVE_WS_PORT=4001
NEXT_PUBLIC_WS_HOST=

# ============================================
# PUSH NOTIFICATIONS (web push VAPID)
# ============================================
# Generate once with `npx web-push generate-vapid-keys`; push silently
# disabled while VAPID_PUBLIC_KEY/VAPID_PRIVATE_KEY are unset.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@cerebrumbiologyacademy.com

# Inbound email-provider webhook auth (?secret=<EMAIL_WEBHOOK_SECRET>)
EMAIL_WEBHOOK_SECRET=
# Destination for admin lead-alert emails (defaults to support@)
ADMIN_LEAD_EMAIL=

# ============================================
# FEATURE FLAGS / DEV TOGGLES
# ============================================
ALLOW_DEMO_ENDPOINTS=false
DISABLE_RATE_LIMIT=false
SKIP_EMAIL_VERIFICATION=false
